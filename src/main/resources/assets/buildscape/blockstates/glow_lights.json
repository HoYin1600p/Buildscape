{
  "multipart": [
    {
      "when": {
        "up": "true"
      },
      "apply": {
        "model": "buildscape:block/glow_lights_up"
      }
    },
    {
      "when": {
        "down": "true"
      },
      "apply": {
        "model": "buildscape:block/glow_lights_down"
      }
    },
    {
      "when": {
        "north": "true"
      },
      "apply": {
        "model": "buildscape:block/glow_lights_north"
      }
    },
    {
      "when": {
        "south": "true"
      },
      "apply": {
        "model": "buildscape:block/glow_lights_south"
      }
    },
    {
      "when": {
        "east": "true"
      },
      "apply": {
        "model": "buildscape:block/glow_lights_east"
      }
    },
    {
      "when": {
        "west": "true"
      },
      "apply": {
        "model": "buildscape:block/glow_lights_west"
      }
    }
  ]
}
