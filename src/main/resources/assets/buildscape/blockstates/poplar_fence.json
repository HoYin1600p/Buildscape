{
    "multipart":  [
                      {
                          "apply":  {
                                        "model":  "buildscape:block/poplar_fence_post"
                                    }
                      },
                      {
                          "when":  {
                                       "east":  "true"
                                   },
                          "apply":  {
                                        "model":  "buildscape:block/poplar_fence_side",
                                        "y":  90
                                    }
                      },
                      {
                          "when":  {
                                       "south":  "true"
                                   },
                          "apply":  {
                                        "model":  "buildscape:block/poplar_fence_side",
                                        "y":  180
                                    }
                      },
                      {
                          "when":  {
                                       "west":  "true"
                                   },
                          "apply":  {
                                        "model":  "buildscape:block/poplar_fence_side",
                                        "y":  270
                                    }
                      },
                      {
                          "when":  {
                                       "north":  "true"
                                   },
                          "apply":  {
                                        "model":  "buildscape:block/poplar_fence_side"
                                    }
                      }
                  ]
}
